# deploy.config
# Configuration file for deployment script
# Copy this to deploy.config and customize for your setup

# Server Configuration
SERVER_USER="ubuntu"                    # Your SSH username
SERVER_HOST="your-server.com"           # Your server IP or domain
SERVER_PATH="/home/ubuntu/myapp"        # Path where app will be deployed

# Local Project Paths
GO_PROJECT_PATH="./go-backend"          # Path to your Go project
ANGULAR_PROJECT_PATH="./angular-frontend" # Path to your Angular project

# Application Configuration
GO_BINARY_NAME="myapp"                  # Name for the Go binary
SYSTEMD_SERVICE_NAME="myapp"            # Name for systemd service

# Build Configuration
GO_OS="linux"                           # Target OS for Go build
GO_ARCH="amd64"                         # Target architecture for Go build

# Optional: Environment variables for the server
# These will be set when starting the service
# SERVER_ENV_VARS="PORT=8080 ENV=production"
