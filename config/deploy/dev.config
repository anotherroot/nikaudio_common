# deploy.config
# Configuration file for deployment script
# Copy this to deploy.config and customize for your setup

# Server Configuration
SERVER_USER="tilen"                    # Your SSH username
SERVER_HOST="49.13.76.224"           # Your server IP or domain
SERVER_PATH="/home/tilen/Services/nikaudio"        # Path where app will be deployed

# Local Project Paths
GO_PROJECT_PATH="../nikaudio-be"          # Path to your Go project
ANGULAR_PROJECT_PATH="../nikaudio-web" # Path to your Angular project

# Application Configuration
GO_BINARY_NAME="nikaudio-go-be"                  # Name for the Go binary
SYSTEMD_SERVICE_NAME="nikaudio"            # Name for systemd service

# Build Configuration
GO_OS="linux"                           # Target OS for Go build
GO_ARCH="amd64"                         # Target architecture for Go build

# Optional: Environment variables for the server
# These will be set when starting the service
# SERVER_ENV_VARS="PORT=8080 ENV=production"
